// Salla Marketing MVP - Prisma Schema
// Multi-tenant, Role-based, Global Services, Soft Deletes, Notifications

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// AUTHENTICATION & MULTI-TENANT
// ============================================================================

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  password   String // bcrypt hashed
  phone      String?
  avatar     String?
  bio        String?
  city       String?
  country    String?
  // ── Merchant profile fields (self-updated via settings) ──
  storeName         String?
  storeUrl          String?
  businessType      String?
  companyName       String?
  storeNotes        String?
  preferredContact  String?
  // ──────────────────────────────────────────────────────
  isActive   Boolean  @default(true)
  globalRole UserRole @default(MERCHANT)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  orgMembers    OrganizationMember[]
  notifications Notification[]
  assignedTasks Task[]
  activityLogs  ActivityLog[]
  expertProfile ExpertProfile?
  orders        Order[] // Phase 11: client orders submitted by this merchant
  projectMessages ProjectMessage[]
  projectDeliveries ProjectDelivery[]
  providerPayouts ProviderPayout[] @relation("ProviderPayouts")
  reviewedPayouts ProviderPayout[] @relation("ReviewedPayouts")

  @@map("users")
}

enum UserRole {
  MERCHANT
  PROVIDER
  ADMIN
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  website   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members       OrganizationMember[]
  plan          OrganizationPlan?
  notifications Notification[]
  merchants     Merchant[]
  leads         Lead[]
  services      Service[]
  orders        ServiceOrder[]
  projects      Project[]
  tasks         Task[]
  landingPages  LandingPage[]
  fileAssets    FileAsset[]
  activityLogs  ActivityLog[]

  @@map("organizations")
}

model OrganizationMember {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role         Role         @default(PROJECT_MANAGER)
  isActive     Boolean      @default(true)
  joinedAt     DateTime     @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
  @@map("organization_members")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  DESIGNER
  MARKETER
  CLIENT
  EXPERT
}

// ============================================================================
// SAAS SUBSCRIPTION
// ============================================================================

model OrganizationPlan {
  id           String       @id @default(cuid())
  orgId        String       @unique
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  plan         SubscriptionPlan @default(FREE)
  monthlyLimit Int              @default(10)
  currentMonth Int              @default(0)
  renewalDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("organization_plans")
}

enum SubscriptionPlan {
  FREE // 10 leads/month
  STARTER // 100 leads/month
  PRO // 1000 leads/month
  ENTERPRISE // unlimited
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

enum NotificationType {
  OFFER_RECEIVED
  OFFER_ACCEPTED
  PROJECT_CREATED
  PROJECT_STARTED
  PROJECT_MESSAGE_RECEIVED
  DELIVERY_SUBMITTED
  DELIVERY_APPROVED
  DELIVERY_REVISION_REQUESTED
  PAYOUT_APPROVED
  PAYOUT_HELD
  PAYOUT_PAID
  GENERAL
}

enum PayoutStatus {
  PENDING_REVIEW
  APPROVED
  ON_HOLD
  PAID
  CANCELLED
}

model Notification {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType @default(GENERAL)
  title   String
  message String
  entityType String?
  entityId   String?
  url        String?
  isRead  Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  readAt    DateTime?

  @@index([orgId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================================
// CRM (MERCHANTS & LEADS)
// ============================================================================

model Merchant {
  id           String         @id @default(cuid())
  orgId        String
  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  storeName    String
  storeUrl     String
  email        String
  phone        String
  contactName  String?
  status       MerchantStatus @default(NEW)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime? // soft delete

  // Relations
  leads      Lead[]
  orders     ServiceOrder[]
  projects   Project[]
  sallaStore SallaStore?

  @@unique([orgId, email])
  @@index([orgId])
  @@index([status])
  @@index([deletedAt])
  @@map("merchants")
}

enum MerchantStatus {
  NEW
  CONTACTED
  QUOTE_SENT
  NEGOTIATING
  CLIENT
  REJECTED
}

model Lead {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String
  storeUrl     String?
  source       String?
  stage        LeadStage    @default(NEW)
  notes        String?
  merchantId   String?
  merchant     Merchant?    @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime? // soft delete

  @@unique([orgId, email])
  @@index([orgId])
  @@index([stage])
  @@index([merchantId])
  @@index([deletedAt])
  @@map("leads")
}

enum LeadStage {
  NEW
  CONTACTED
  QUOTE_SENT
  NEGOTIATING
  CLIENT
  REJECTED
}

// ============================================================================
// SERVICES & CATEGORIES
// ============================================================================

enum ServiceStatus {
  AVAILABLE
  LIMITED
  COMING_SOON
  DISABLED
}

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String   @unique // Legacy, keep for safety
  nameAr      String   @unique
  nameEn      String   @unique
  slug        String   @unique
  sortOrder   Int      @default(0)
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services Service[]

  @@index([isActive])
  @@map("service_categories")
}

model Service {
  id            String           @id @default(cuid())
  // NO orgId - GLOBAL services
  categoryId    String?
  category      ServiceCategory? @relation(fields: [categoryId], references: [id])
  name          String           @unique // Legacy, keep for safety
  nameAr        String           @unique
  nameEn        String           @unique
  slug          String           @unique
  description   String? // Legacy, keep for safety
  descriptionAr String?
  descriptionEn String?
  status        ServiceStatus    @default(AVAILABLE)
  sortOrder     Int              @default(0)
  isActive      Boolean          @default(true) // Dynamic status based on experts
  icon          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  orders         ServiceOrder[]
  clientOrders   Order[] // Phase 2: client requests linked to the canonical service
  projects       Project[]
  expertServices ExpertService[]
  Organization   Organization?   @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@index([isActive])
  @@index([categoryId])
  @@index([status])
  @@map("services")
}

// ============================================================================
// EXPERTS / FREELANCERS & APPROVAL WORKFLOW
// ============================================================================

enum ProviderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model ExpertProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Public Profile
  specialtyTitle       String?
  bio                  String?
  yearsOfExperience    Int?
  portfolioUrl         String?
  linkedinUrl          String?
  availability         String?
  priceRangeMin        Float?
  priceRangeMax        Float?
  preferredProjectTypes String?
  sallaExperience      String?

  // Approval Workflow
  approvalStatus  ProviderApprovalStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services         ExpertService[]
  portfolioItems   PortfolioItem[]
  offers           Offer[]
  offerInvitations OfferInvitation[]
  projects         Project[]

  @@index([approvalStatus])
  @@map("expert_profiles")
}

model PortfolioItem {
  id          String        @id @default(cuid())
  expertId    String
  expert      ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  title       String
  description String?
  projectUrl  String?
  fileUrl     String?
  serviceId   String? // Optionally link to a specific Service
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([expertId])
  @@map("portfolio_items")
}

model ExpertService {
  id        String        @id @default(cuid())
  expertId  String
  expert    ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Provider-specific Service Offerings
  startingPrice       Float?
  typicalDeliveryDays Int?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([expertId, serviceId])
  @@map("expert_services")
}

model ServiceOrder {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  merchantId   String
  merchant     Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  serviceId    String
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  description  String
  status       OrderStatus  @default(NEW)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime? // soft delete

  // Relations
  fileAssets  FileAsset[]
  activityLog ActivityLog[]

  @@index([orgId])
  @@index([merchantId])
  @@index([serviceId])
  @@index([status])
  @@index([deletedAt])
  @@map("service_orders")
}

enum OrderStatus {
  NEW
  WAITING_REQUIREMENTS
  IN_PROGRESS
  AWAITING_REVIEW
  COMPLETED
  CANCELLED
}

// ============================================================================
// PROJECTS & TASKS
// ============================================================================

model Project {
  id               String         @id @default(cuid())
  orgId            String
  organization     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name             String
  merchantId       String?
  merchant         Merchant?      @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  serviceId        String?
  service          Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  orderId          String         @unique
  order            Order          @relation("OrderProject", fields: [orderId], references: [id], onDelete: Cascade)
  acceptedOfferId  String?        @unique
  acceptedOffer    Offer?         @relation("AcceptedOfferProject", fields: [acceptedOfferId], references: [id], onDelete: SetNull)
  expertProfileId  String?
  expertProfile    ExpertProfile? @relation(fields: [expertProfileId], references: [id], onDelete: SetNull)
  status           ProjectStatus  @default(KICKOFF_PENDING)
  startDate        DateTime?
  dueDate          DateTime?
  completedDate    DateTime?
  description      String?
  scopeSummary     String?
  deliverables     String?
  price            Float?
  deliveryDays     Int?
  revisionsIncluded Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  tasks      Task[]
  fileAssets FileAsset[]
  messages   ProjectMessage[]
  deliveries ProjectDelivery[]
  payout     ProviderPayout?

  @@unique([orgId, orderId])
  @@index([orgId])
  @@index([merchantId])
  @@index([acceptedOfferId])
  @@index([expertProfileId])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

enum ProjectStatus {
  KICKOFF_PENDING
  ACTIVE
  PAUSED
  DELIVERED
  REVISION_REQUESTED
  PENDING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum DeliveryStatus {
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
  CANCELLED
}

model ProjectMessage {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  senderUserId String
  senderUser   User      @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  body         String
  readAt       DateTime?
  isInternal   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([projectId, createdAt])
  @@index([senderUserId])
  @@index([isInternal])
  @@map("project_messages")
}

model ProjectDelivery {
  id                  String         @id @default(cuid())
  projectId           String
  project             Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedById       String
  submittedBy         User           @relation(fields: [submittedById], references: [id])
  status              DeliveryStatus @default(SUBMITTED)
  title               String
  description         String
  deliverableLinks    String?
  revisionNote        String?
  submittedAt         DateTime       @default(now())
  approvedAt          DateTime?
  revisionRequestedAt DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([projectId, status])
  @@index([submittedById])
  @@map("project_deliveries")
}

model ProviderPayout {
  id           String       @id @default(cuid())
  projectId    String       @unique
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  providerId   String
  provider     User         @relation("ProviderPayouts", fields: [providerId], references: [id])
  amount       Float        // net amount after platform fee
  platformFee  Float        // BOROZ commission
  grossAmount  Float        // total project value from accepted offer
  status       PayoutStatus @default(PENDING_REVIEW)
  holdReason   String?
  reviewedById String?
  reviewedBy   User?        @relation("ReviewedPayouts", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([providerId])
  @@index([status])
  @@map("provider_payouts")
}

model Task {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  assignedToId String?
  assignedTo   User?        @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  status       TaskStatus   @default(NOT_STARTED)
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime? // soft delete

  // Relations
  fileAssets FileAsset[]

  @@index([orgId])
  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
  @@index([deletedAt])
  @@map("tasks")
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  AWAITING_CLIENT
  COMPLETED
}

// ============================================================================
// FILE MANAGEMENT
// ============================================================================

model FileAsset {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  fileName   String
  fileUrl    String
  fileSize   Int?
  fileType   String?
  uploadedBy String?

  orderId   String?
  order     ServiceOrder? @relation(fields: [orderId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([orderId])
  @@index([projectId])
  @@index([taskId])
  @@map("file_assets")
}

// ============================================================================
// LANDING PAGES
// ============================================================================

model LandingPage {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?
  ctaText     String   @default("تواصل معنا")
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  submissions LandingPageSubmission[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([isPublished])
  @@map("landing_pages")
}

model LandingPageSubmission {
  id            String      @id @default(cuid())
  landingPageId String
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String
  message   String?
  storeUrl  String?
  createdAt DateTime @default(now())

  @@index([landingPageId])
  @@index([email])
  @@map("landing_page_submissions")
}

// ============================================================================
// INTEGRATIONS
// ============================================================================

model SallaStore {
  id           String    @id @default(cuid())
  merchantId   String    @unique
  merchant     Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  storeUrl     String
  accessToken  String?
  refreshToken String?
  connectedAt  DateTime?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([merchantId])
  @@map("salla_stores")
}

// ============================================================================
// PLATFORM SETTINGS
// ============================================================================

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("platform_settings")
}

// ============================================================================
// AUDIT
// ============================================================================

model ActivityLog {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId       String?

  action   String // "create", "update", "delete", "status_change"
  entity   String // "Merchant", "Lead", "Order", etc
  entityId String
  changes  String? // JSON

  createdAt      DateTime      @default(now())
  User           User?         @relation(fields: [userId], references: [id])
  ServiceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  serviceOrderId String?

  @@index([orgId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================================
// CLIENT ORDERS (PHASE 11)
// ============================================================================

model Order {
  id           String    @id @default(cuid())
  orderNumber  String    @unique
  // ── Merchant ownership (data isolation) ──────────────────────
  userId       String? // The User who submitted this order (MERCHANT)
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  orgId        String?
  merchantId   String?
  // ─────────────────────────────────────────────────────────────
  storeName    String
  managerName  String
  phone        String
  email        String?
  sallaUrl     String?
  serviceType  String // denormalized service slug/label cache (kept for legacy + display)
  serviceId    String? // Phase 2: canonical service reference
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  budget       String?
  priority     String    @default("عادي")
  description  String
  notes        String?
  status       String    @default("SUBMITTED")
  adminNote    String?
  internalNote String?
  selectedOfferId String?   @unique
  reviewedAt   DateTime?
  reviewedById String?
  source       String    @default("website")
  offersOpenedAt DateTime?
  offersClosedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  offers       Offer[]           @relation("OrderOffers")
  invitations  OfferInvitation[] @relation("OrderInvitations")
  selectedOffer Offer?           @relation("SelectedOffer", fields: [selectedOfferId], references: [id], onDelete: SetNull)
  project      Project?          @relation("OrderProject")

  @@index([userId])
  @@index([orgId])
  @@index([merchantId])
  @@index([serviceId])
  @@index([status])
  @@index([selectedOfferId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([serviceType, createdAt])
  @@map("orders")
}

enum OfferStatus {
  DRAFT
  SUBMITTED
  WITHDRAWN
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OfferInvitationStatus {
  INVITED
  VIEWED
  DECLINED
  OFFER_SUBMITTED
  EXPIRED
}

model Offer {
  id                String      @id @default(cuid())
  orderId           String
  order             Order       @relation("OrderOffers", fields: [orderId], references: [id], onDelete: Cascade)
  expertProfileId   String
  expertProfile     ExpertProfile @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)
  status            OfferStatus @default(SUBMITTED)
  price             Float
  deliveryDays      Int
  scopeSummary      String
  deliverables      String
  revisionsIncluded Int
  assumptions       String
  exclusions        String
  messageToMerchant String
  submittedAt       DateTime?
  acceptedAt        DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  selectedByOrder   Order?      @relation("SelectedOffer")
  project           Project?    @relation("AcceptedOfferProject")

  @@unique([orderId, expertProfileId])
  @@index([orderId])
  @@index([expertProfileId])
  @@index([status])
  @@map("offers")
}

model OfferInvitation {
  id              String                @id @default(cuid())
  orderId         String
  order           Order                 @relation("OrderInvitations", fields: [orderId], references: [id], onDelete: Cascade)
  expertProfileId String
  expertProfile   ExpertProfile         @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)
  status          OfferInvitationStatus @default(INVITED)
  invitedAt       DateTime              @default(now())
  expiresAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([orderId, expertProfileId])
  @@index([orderId])
  @@index([expertProfileId])
  @@index([status])
  @@map("offer_invitations")
}
